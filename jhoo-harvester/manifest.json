{
  "manifest_version": 3,
  "name": "jhoo Harvester",
  "version": "1.0",
  "description": "Captures LinkedIn job descriptions as you browse and sends them to jhoo",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/jobs/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
